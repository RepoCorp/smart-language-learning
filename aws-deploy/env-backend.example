DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=api.yourdomain.com
POSTGRES_DB=smart_language_learning
POSTGRES_USER=smart_language_learning
POSTGRES_HOST=<RDS_ENDPOINT>
POSTGRES_PORT=5432
# Set in Secrets Manager
DJANGO_SECRET_KEY=<secret>
POSTGRES_PASSWORD=<secret>
GUNICORN_TIMEOUT=120
OPENAI_REQUEST_TIMEOUT_SECONDS=30
OPENAI_TTS_REQUEST_TIMEOUT_SECONDS=40
OPENAI_MODEL=gpt-4o-mini
OPENAI_QUESTION_MODEL=gpt-4o-mini
AUDIO_STORAGE_BACKEND=s3
AWS_S3_AUDIO_BUCKET=<S3_BUCKET_NAME>
AWS_S3_AUDIO_PREFIX=audio
AWS_S3_AUDIO_REGION=<AWS_REGION>
# Optional; set if using CloudFront/custom domain, e.g. https://cdn.yourdomain.com
AWS_S3_AUDIO_BASE_URL=
# Optional; defaults to the audio S3 settings when omitted
IMAGE_STORAGE_BACKEND=s3
AWS_S3_IMAGE_BUCKET=<S3_BUCKET_NAME>
AWS_S3_IMAGE_PREFIX=exercise-images
AWS_S3_IMAGE_REGION=<AWS_REGION>
AWS_S3_IMAGE_BASE_URL=
